DATABASE_URL=postgresql://portfolio:portfolio@localhost:5433/yatirim_portfoyu?schema=public
DIRECT_URL=postgresql://portfolio:portfolio@localhost:5433/yatirim_portfoyu?schema=public

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Twelve Data: ücretsiz (Basic) plan BIST/Türkiye kapsamaz; Grow+ gerekir.
# BIST hisseleri anahtar yoksa veya plan yetersizse Yahoo Finance ile çekilir.
TWELVE_DATA_API_KEY=
# TCMB EVDS (ücretsiz): https://evds2.tcmb.gov.tr — yoksa resmi TÜFE fallback kullanılır
TCMB_EVDS_API_KEY=

CRON_SECRET=change-me-to-a-long-random-secret
ENCRYPTION_KEY=change-me-to-a-32-char-encryption-key

# Demo auth (Supabase olmadan kişisel kullanım)
AUTH_SECRET=change-me-to-a-long-random-auth-secret
DEMO_MODE=true

# Davet kodlu kayıt (kapalı kitle). Boş = kayıt kapalı.
INVITE_CODE=
# Demo giriş butonu: prod'da boş bırakın / "false". Sadece "true" ise görünür.
NEXT_PUBLIC_ENABLE_DEMO=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
