generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AssetType {
  STOCK
  MUTUAL_FUND
  ETF
  CASH
  FX
  GOLD
  CRYPTO
  OTHER
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  FUND_DISTRIBUTION
  COMMISSION
  TAX
  CASH_DEPOSIT
  CASH_WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  BONUS_ISSUE
  RIGHTS_ISSUE
  SPLIT
  OTHER
}

enum AccountType {
  BROKERAGE
  BANK
  CASH
  OTHER
}

enum BenchmarkType {
  INDEX
  FX
  COMMODITY
  FUND
  INFLATION
  CUSTOM
}

enum AlertType {
  ASSET_DAILY_RETURN
  ASSET_AVG_DAILY_RETURN
  PORTFOLIO_DAILY_LOSS
  PORTFOLIO_DRAWDOWN
  ASSET_WEIGHT
  MONTHLY_REAL_RETURN_NEGATIVE
  ASSET_PRICE
  DATA_STALE
}

enum ComparisonOperator {
  GREATER_THAN
  GREATER_THAN_OR_EQUAL
  LESS_THAN
  LESS_THAN_OR_EQUAL
  CROSSES_ABOVE
  CROSSES_BELOW
}

enum InsightPeriodType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

enum InsightCategory {
  PERFORMANCE
  RISK
  CONCENTRATION
  INFLATION
  BENCHMARK
  CONTRIBUTION
  DRAWDOWN
  TREND
  DATA_QUALITY
}

enum InsightSeverity {
  INFO
  POSITIVE
  WARNING
  CRITICAL
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum DataQuality {
  LIVE
  DELAYED
  END_OF_DAY
  STALE
  MANUAL
  ERROR
}

enum RealizedGainMethod {
  WEIGHTED_AVERAGE
  FIFO
}

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  name                 String?
  passwordHash         String?
  baseCurrency         String     @default("TRY")
  timezone             String     @default("Europe/Istanbul")
  riskFreeRateAnnual   Decimal    @default(0.45) @db.Decimal(12, 8)
  preferredBenchmarkId String?
  isDemo               Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  portfolios           Portfolio[]
  sessions             Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Portfolio {
  id                    String                  @id @default(cuid())
  userId                String
  name                  String
  baseCurrency          String                  @default("TRY")
  isDefault             Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts              Account[]
  transactions          Transaction[]
  dailySnapshots        PortfolioDailySnapshot[]
  positionSnapshots     PositionDailySnapshot[]
  realizedGains         RealizedGain[]
  alertRules            AlertRule[]
  analysisInsights      AnalysisInsight[]
  reports               PortfolioReport[]

  @@index([userId])
  @@map("portfolios")
}

model Account {
  id           String        @id @default(cuid())
  portfolioId  String
  name         String
  institution  String?
  accountType  AccountType   @default(BROKERAGE)
  currency     String        @default("TRY")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([portfolioId])
  @@map("accounts")
}

model Asset {
  id                String                  @id @default(cuid())
  symbol            String
  name              String
  assetType         AssetType
  exchange          String?
  currency          String                  @default("TRY")
  providerSymbol    String?
  provider          String?
  isin              String?
  tefasCode         String?
  isActive          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  transactions      Transaction[]
  prices            AssetPrice[]
  positionSnapshots PositionDailySnapshot[]
  realizedGains     RealizedGain[]
  alertRules        AlertRule[]

  @@unique([symbol, assetType])
  @@index([symbol])
  @@index([tefasCode])
  @@index([isActive])
  @@map("assets")
}

model Transaction {
  id              String          @id @default(cuid())
  portfolioId     String
  accountId       String
  assetId         String?
  transactionType TransactionType
  transactionDate DateTime        @db.Date
  settlementDate  DateTime?       @db.Date
  quantity        Decimal         @default(0) @db.Decimal(24, 8)
  unitPrice       Decimal         @default(0) @db.Decimal(24, 8)
  grossAmount     Decimal         @default(0) @db.Decimal(24, 8)
  commission      Decimal         @default(0) @db.Decimal(24, 8)
  tax             Decimal         @default(0) @db.Decimal(24, 8)
  otherCost       Decimal         @default(0) @db.Decimal(24, 8)
  currency        String          @default("TRY")
  fxRateToBase    Decimal         @default(1) @db.Decimal(24, 8)
  notes           String?
  importHash      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  portfolio       Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account         Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset           Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)
  realizedGains   RealizedGain[]

  @@index([portfolioId, transactionDate])
  @@index([assetId])
  @@index([accountId])
  @@index([importHash])
  @@map("transactions")
}

model AssetPrice {
  id             String       @id @default(cuid())
  assetId        String
  priceDate      DateTime     @db.Date
  open           Decimal?     @db.Decimal(24, 8)
  high           Decimal?     @db.Decimal(24, 8)
  low            Decimal?     @db.Decimal(24, 8)
  close          Decimal      @db.Decimal(24, 8)
  previousClose  Decimal?     @db.Decimal(24, 8)
  volume         Decimal?     @db.Decimal(24, 4)
  currency       String       @default("TRY")
  source         String
  dataQuality    DataQuality  @default(DELAYED)
  isDelayed      Boolean      @default(true)
  fetchedAt      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  asset          Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, priceDate, source])
  @@index([assetId, priceDate])
  @@index([fetchedAt])
  @@map("asset_prices")
}

model InflationIndex {
  id          String   @id @default(cuid())
  countryCode String   @default("TR")
  indexType   String   @default("TUFE")
  period      String
  indexValue  Decimal  @db.Decimal(18, 6)
  monthlyRate Decimal? @db.Decimal(12, 8)
  annualRate  Decimal? @db.Decimal(12, 8)
  source      String
  fetchedAt   DateTime @default(now())

  @@unique([countryCode, indexType, period])
  @@index([period])
  @@map("inflation_indices")
}

model Benchmark {
  id            String           @id @default(cuid())
  name          String
  symbol        String           @unique
  benchmarkType BenchmarkType
  currency      String           @default("TRY")
  provider      String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  prices        BenchmarkPrice[]

  @@map("benchmarks")
}

model BenchmarkPrice {
  id          String    @id @default(cuid())
  benchmarkId String
  priceDate   DateTime  @db.Date
  value       Decimal   @db.Decimal(24, 8)
  source      String
  fetchedAt   DateTime  @default(now())
  benchmark   Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@unique([benchmarkId, priceDate, source])
  @@index([benchmarkId, priceDate])
  @@map("benchmark_prices")
}

model PortfolioDailySnapshot {
  id                      String   @id @default(cuid())
  portfolioId             String
  snapshotDate            DateTime @db.Date
  totalMarketValue        Decimal  @db.Decimal(24, 8)
  cashValue               Decimal  @default(0) @db.Decimal(24, 8)
  investedCapital         Decimal  @default(0) @db.Decimal(24, 8)
  netContributions        Decimal  @default(0) @db.Decimal(24, 8)
  dailyExternalCashFlow   Decimal  @default(0) @db.Decimal(24, 8)
  dailyProfitLoss         Decimal  @default(0) @db.Decimal(24, 8)
  dailyReturn             Decimal? @db.Decimal(18, 10)
  cumulativeProfitLoss    Decimal  @default(0) @db.Decimal(24, 8)
  cumulativeReturn        Decimal? @db.Decimal(18, 10)
  twrDailyFactor          Decimal? @db.Decimal(18, 10)
  twrCumulative           Decimal? @db.Decimal(18, 10)
  inflationAdjustedCapital Decimal? @db.Decimal(24, 8)
  realProfitLoss          Decimal? @db.Decimal(24, 8)
  realReturn              Decimal? @db.Decimal(18, 10)
  valueInUsd              Decimal? @db.Decimal(24, 8)
  valueInEur              Decimal? @db.Decimal(24, 8)
  createdAt               DateTime @default(now())
  portfolio               Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, snapshotDate])
  @@index([portfolioId, snapshotDate])
  @@map("portfolio_daily_snapshots")
}

model PositionDailySnapshot {
  id                         String   @id @default(cuid())
  portfolioId                String
  assetId                    String
  accountId                  String   @default("")
  snapshotDate               DateTime @db.Date
  quantity                   Decimal  @db.Decimal(24, 8)
  averageCost                Decimal  @db.Decimal(24, 8)
  marketPrice                Decimal  @db.Decimal(24, 8)
  marketValue                Decimal  @db.Decimal(24, 8)
  dailyProfitLoss            Decimal  @default(0) @db.Decimal(24, 8)
  dailyReturn                Decimal? @db.Decimal(18, 10)
  unrealizedProfitLoss       Decimal  @default(0) @db.Decimal(24, 8)
  totalReturn                Decimal? @db.Decimal(18, 10)
  portfolioWeight            Decimal? @db.Decimal(12, 8)
  contributionToDailyReturn  Decimal? @db.Decimal(18, 10)
  createdAt                  DateTime @default(now())
  portfolio                  Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset                      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, assetId, snapshotDate, accountId])
  @@index([portfolioId, snapshotDate])
  @@index([assetId, snapshotDate])
  @@map("position_daily_snapshots")
}

model RealizedGain {
  id             String             @id @default(cuid())
  portfolioId    String
  assetId        String
  transactionId  String
  realizedAmount Decimal            @db.Decimal(24, 8)
  costBasis      Decimal            @db.Decimal(24, 8)
  proceeds       Decimal            @db.Decimal(24, 8)
  method         RealizedGainMethod @default(WEIGHTED_AVERAGE)
  realizedAt     DateTime           @db.Date
  portfolio      Portfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset          Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  transaction    Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([portfolioId, realizedAt])
  @@index([assetId])
  @@map("realized_gains")
}

model AlertRule {
  id                  String             @id @default(cuid())
  portfolioId         String
  assetId             String?
  name                String
  alertType           AlertType
  comparisonOperator  ComparisonOperator
  threshold           Decimal            @db.Decimal(24, 8)
  lookbackDays        Int?
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  portfolio           Portfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset               Asset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  events              AlertEvent[]

  @@index([portfolioId, isActive])
  @@map("alert_rules")
}

model AlertEvent {
  id           String    @id @default(cuid())
  alertRuleId  String
  triggeredAt  DateTime  @default(now())
  currentValue Decimal   @db.Decimal(24, 8)
  message      String
  isRead       Boolean   @default(false)
  alertRule    AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)

  @@index([alertRuleId, triggeredAt])
  @@index([isRead])
  @@map("alert_events")
}

model AnalysisInsight {
  id           String            @id @default(cuid())
  portfolioId  String
  insightDate  DateTime          @db.Date
  periodType   InsightPeriodType @default(DAILY)
  category     InsightCategory
  severity     InsightSeverity   @default(INFO)
  title        String
  message      String
  fingerprint  String
  metadata     Json?
  createdAt    DateTime          @default(now())
  portfolio    Portfolio         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, fingerprint, insightDate])
  @@index([portfolioId, insightDate])
  @@index([category])
  @@map("analysis_insights")
}

model DataSyncLog {
  id               String     @id @default(cuid())
  provider         String
  syncType         String
  startedAt        DateTime   @default(now())
  completedAt      DateTime?
  status           SyncStatus @default(RUNNING)
  recordsProcessed Int        @default(0)
  errorMessage     String?
  metadata         Json?

  @@index([provider, startedAt])
  @@index([status])
  @@map("data_sync_logs")
}

model PortfolioReport {
  id          String   @id @default(cuid())
  portfolioId String
  reportType  String
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  title       String
  summary     String
  content     Json
  createdAt   DateTime @default(now())
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, reportType, periodStart, periodEnd])
  @@index([portfolioId, reportType])
  @@map("portfolio_reports")
}

model AppSetting {
  id        String   @id @default(cuid())
  userId    String?
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@map("app_settings")
}
